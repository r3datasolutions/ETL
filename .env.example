# Plantilla de configuración. Copia este archivo a .env y rellena los valores.
#   cp .env.example .env
#
# IMPORTANTE: .env está en .gitignore y NUNCA debe subirse al repositorio.
# Este .env.example sí se versiona, porque solo documenta la FORMA de la
# configuración, sin valores reales.

# Sal secreta para la seudonimización de PII (scripts/anonimizar.py).
# Debe ser un valor largo y aleatorio, y mantenerse estable: si cambia,
# los seudónimos cambian y se pierde la trazabilidad entre versiones.
ANONIM_SALT=
