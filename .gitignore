# === Entorno virtual de Python ===
.venv/
venv/
env/

# === Cache de Python ===
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# === Jupyter Notebooks ===
.ipynb_checkpoints/

# === macOS ===
.DS_Store

# === Power BI (archivos temporales/backup) ===
*.pbix.tmp
*~$*

# ===========================================================
# SECRETOS — nunca deben entrar a git
# ===========================================================
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.*

# ===========================================================
# DATOS SENSIBLES (PII) — ver docs/SEGURIDAD.md
# ===========================================================
# Regla: la PII se anonimiza en Silver (scripts/anonimizar.py).
# Las tablas que NO se pueden anonimizar porque necesitan el dato
# real quedan fuera de git y se regeneran localmente desde la fuente.
#
#   security.csv -> Power BI necesita el UserEmail REAL para el
#                   Row-Level Security, así que no se versiona.
data/bronze/security.csv
data/silver/security.csv

# -----------------------------------------------------------
# NOTA: el resto de data/ SÍ se versiona a propósito. El objetivo
# del proyecto es llevar el registro de los datos en cada etapa
# (bronze -> silver -> gold). NO lo ignoramos.
# Si algún archivo de datos supera ~50 MB, avísame para
# configurar Git LFS.
# -----------------------------------------------------------
